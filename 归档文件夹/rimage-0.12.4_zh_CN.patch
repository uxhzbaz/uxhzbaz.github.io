+/// RAII guard that updates progress bars on drop, ensuring they advance
+/// even when a worker returns early due to an error.
+struct FinishGuard {
+    pb: ProgressBar,
+    pb_main: ProgressBar,
+}
+
+impl Drop for FinishGuard {
+    fn drop(&mut self) {
+        self.pb.finish_and_clear();
+        self.pb_main.inc(1);
+    }
+}
